// 部署於 Supabase Edge Functions
import { createClient } from 'https://esm.sh/@supabase/supabase-client'

const TG_BOT_TOKEN = Deno.env.get('TELEGRAM_TOKEN');
const ADMIN_ID = Deno.env.get('MY_CHAT_ID');

Deno.serve(async (req) => {
  // 1. 執行抓取 (以 GitHub 為例)
  const trending = await fetch('https://api.github.com/search/repositories?q=topic:automation&sort=stars');
  const items = await trending.json();

  // 2. AI 篩選 (調用 OpenAI 進行商業價值評估)
  for (const item of items.items.slice(0, 5)) {
    const aiAnalysis = await analyzeWithAI(item.description); 
    
    if (aiAnalysis.roi > 5.0) { // ROI 高於 500%
      // 3. 存入 Supabase 向量資料庫
      await supabase.from('insights').insert({ ...item, vector: aiAnalysis.embedding });

      // 4. Telegram 轟炸
      await fetch(`https://api.telegram.org/bot${TG_BOT_TOKEN}/sendMessage`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          chat_id: ADMIN_ID,
          text: `🚨 【高價值發現】\n技術：${item.name}\n分析：${aiAnalysis.summary}\nROI：${aiAnalysis.roi}x`,
          reply_markup: {
            inline_keyboard: [[
              { text: "🚀 部署測試", callback_data: `deploy_${item.id}` },
              { text: "📁 存檔", callback_data: `archive_${item.id}` }
            ]]
          }
        })
      });
    }
  }
  return new Response("Scan Completed");
})
